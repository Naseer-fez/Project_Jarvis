# Jarvis Configuration Secrets
# Copy this file to .env and fill in your keys

OLLAMA_ENDPOINT=http://localhost:11434
LOG_LEVEL=INFO

# Google Gemini API key used as the primary fallback for LLM operations.
# Get an API key from https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"

# ── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
# Numeric chat ID to send messages to (yours or a group)
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# ── Google Calendar + Gmail (OAuth2 Refresh Token) ───────────────────────────
# Create credentials at: https://console.cloud.google.com/
# Scopes needed: calendar.events, gmail.readonly, gmail.send, gmail.modify
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_REFRESH_TOKEN="your_google_refresh_token_here"

# ── Notion ───────────────────────────────────────────────────────────────────
# Internal integration token from https://www.notion.so/my-integrations
NOTION_API_KEY="secret_your_notion_api_key_here"

# ── Spotify ──────────────────────────────────────────────────────────────────
# App credentials from https://developer.spotify.com/dashboard
# Scopes needed: user-read-playback-state, user-modify-playback-state,
#                user-read-currently-playing, playlist-modify-public,
#                playlist-modify-private
SPOTIFY_CLIENT_ID="your_spotify_client_id_here"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret_here"
SPOTIFY_REFRESH_TOKEN="your_spotify_refresh_token_here"
