# JARVIS Configuration - Session 5
# Copy this to .env and fill in your values

# ── Porcupine Wake Word ──────────────────────────────
# Get FREE key at: https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=your_free_key_here

# ── Ollama ───────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
PLANNING_MODEL=deepseek-r1:8b
VISION_MODEL=llava

# ── Whisper STT ──────────────────────────────────────
# Options: tiny, base, small, medium (larger = more accurate but slower)
WHISPER_MODEL=base

# ── Memory ───────────────────────────────────────────
SQLITE_DB_PATH=jarvis_memory.db
CHROMA_DB_DIR=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Risk Evaluator ───────────────────────────────────
# Max score before auto-approve (0-100)
AUTO_APPROVE_THRESHOLD=25

# ── Audio ────────────────────────────────────────────
SAMPLE_RATE=16000
SILENCE_THRESHOLD=500
MAX_RECORD_SECONDS=30

# ── Piper TTS ────────────────────────────────────────
PIPER_MODEL_PATH=models/piper/en_US-lessac-medium.onnx
