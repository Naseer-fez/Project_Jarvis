{
  "schema_version": "1.0",
  "product_name": "Jarvis AI OS",
  "mission": "A local-first personal AI automation operating system that combines agents, workflows, integrations, knowledge, voice, and background execution behind a simple user experience.",
  "philosophy": {
    "principles": [
      {
        "id": "zero-hardcoded-logic",
        "title": "Zero Hardcoded Logic",
        "summary": "Environment-specific values come from config, env vars, manifests, registry metadata, or runtime discovery.",
        "enforcement": [
          "Use config-backed paths and service endpoints",
          "Load plugins and workflow templates from manifests",
          "Reject workflow templates with absolute paths or embedded local URLs"
        ]
      },
      {
        "id": "loose-coupling",
        "title": "No Tight Coupling",
        "summary": "Components communicate through contracts, events, registries, and service abstractions.",
        "enforcement": [
          "UI talks through HTTP/WebSocket APIs",
          "Agents use tool and integration registries",
          "Workflow nodes resolve dynamically"
        ]
      },
      {
        "id": "common-user-first",
        "title": "Common User First",
        "summary": "Beginner workflows, guided setup, and natural language automation hide advanced internals until requested.",
        "enforcement": [
          "Expose templates and one-click installs",
          "Separate beginner and advanced modes",
          "Prefer visual logs and readable block names"
        ]
      },
      {
        "id": "local-first",
        "title": "Local First",
        "summary": "Default to local execution, local storage, offline operation, and user-owned data. Cloud services are optional extensions.",
        "enforcement": [
          "Prefer local LLM providers and local embeddings",
          "Keep workflow state and memory on device",
          "Mark network permissions explicitly"
        ]
      },
      {
        "id": "massive-extensibility",
        "title": "Massive Extensibility",
        "summary": "Everything important can be extended by plugins, workflow nodes, agents, providers, and community packs.",
        "enforcement": [
          "Manifest-based plugin metadata",
          "Typed contribution categories",
          "Versioned workflow definitions"
        ]
      }
    ]
  },
  "layers": [
    {
      "id": "ui-layer",
      "name": "UI Layer",
      "responsibilities": [
        "Dashboard",
        "AI chat",
        "Workflow builder",
        "Notifications",
        "Settings",
        "Marketplace",
        "Agent monitor",
        "Visual logs"
      ],
      "interfaces": ["HTTP API", "WebSocket events", "plugin UI contributions"],
      "extensibility": ["UI widgets", "themes", "workflow panels"]
    },
    {
      "id": "workflow-engine",
      "name": "Workflow Engine",
      "responsibilities": [
        "Versioned JSON workflows",
        "Trigger nodes",
        "AI nodes",
        "Logic nodes",
        "Human approval nodes",
        "Retries",
        "Run history"
      ],
      "interfaces": ["workflow catalog", "tool registry", "event bus"],
      "extensibility": ["custom nodes", "reusable subflows", "template packs"]
    },
    {
      "id": "ai-agent-layer",
      "name": "AI Agent Layer",
      "responsibilities": [
        "Planning",
        "Tool usage",
        "Memory retrieval",
        "Workflow generation",
        "Autonomous execution",
        "Voice interaction"
      ],
      "interfaces": ["LLM provider router", "tool permissions", "memory contracts"],
      "extensibility": ["custom agents", "provider adapters", "tool packs"]
    },
    {
