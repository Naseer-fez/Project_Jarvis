{
  "id": "daily-email-digest",
  "name": "Daily Email Digest",
  "version": "1.0.0",
  "description": "Runs on the user's configured schedule, summarizes unread email from an enabled provider, asks for approval, and saves a digest locally.",
  "mode": "beginner",
  "tags": ["email", "schedule", "summarization", "approval"],
  "trigger": {
    "type": "schedule.cron",
    "config_ref": "user.email_digest_schedule"
  },
  "permissions": [
    {
      "scope": "email",
      "access": "read",
      "reason": "Read unread email from the provider selected by the user."
    },
    {
      "scope": "memory",
      "access": "write",
      "reason": "Save the approved digest into local memory."
    },
    {
      "scope": "notifications",
      "access": "write",
      "reason": "Notify the user when the digest is ready."
    }
  ],
  "nodes": [
    {
      "id": "scheduled_trigger",
      "type": "schedule.cron",
      "tool": "scheduled_trigger",
      "name": "Run On Schedule",
      "category": "Scheduling",
      "config": {
        "schedule_ref": "user.email_digest_schedule"
      }
    },
    {
      "id": "load_unread_email",
      "type": "productivity.email_reader",
      "tool": "list_unread_email",
      "name": "Load Unread Email",
      "category": "Productivity Apps",
      "config": {
        "account_ref": "integrations.email.default_account",
        "limit_ref": "workflow.email_digest_limit"
      }
    },
    {
      "id": "summarize_email",
      "type": "ai.summarizer",
      "tool": "summarize_text",
      "name": "Summarize Email",
      "category": "AI",
      "config": {
        "text_ref": "${load_unread_email.messages}",
        "style": "brief_prioritized_digest",
        "provider_ref": "ai.default_provider"
      }
    },
    {
      "id": "approval",
      "type": "human.approval",
      "tool": "request_approval",
      "name": "Review Digest",
      "category": "Security",
      "config": {
        "summary_ref": "${summarize_email.summary}",
        "prompt": "Save today's email digest?"
      }
    },
    {
      "id": "save_digest",
      "type": "memory.note_writer",
      "tool": "memory_write",
      "name": "Save Digest",
      "category": "Memory",
      "config": {
        "title_template": "Daily Email Digest",
        "body_ref": "${summarize_email.summary}",
        "collection_ref": "memory.default_notes_collection"
      }
    },
    {
      "id": "notify_user",
      "type": "notifications.local",
      "tool": "notification",
      "name": "Notify User",
      "category": "Notifications",
      "config": {
        "message_template": "Your email digest is ready."
      }
    }
  ],
  "edges": [
    {"from": "scheduled_trigger", "to": "load_unread_email"},
    {"from": "load_unread_email", "to": "summarize_email"},
    {"from": "summarize_email", "to": "approval"},
    {"from": "approval", "to": "save_digest"},
    {"from": "save_digest", "to": "notify_user"}
  ],
  "marketplace": {
    "one_click_install": true,
    "difficulty": "beginner",
    "preview_required": true,
    "local_first": true
  }
}
