{
  "id": "downloads-pdf-summary",
  "name": "Sort Downloads and Summarize PDFs",
  "version": "1.0.0",
  "description": "Watches the configured downloads folder, detects PDFs, extracts text, summarizes them locally, and stores the summary in notes after permission review.",
  "mode": "beginner",
  "tags": ["filesystem", "pdf", "summarization", "notes"],
  "trigger": {
    "type": "filesystem.folder_watcher",
    "config_ref": "user.downloads_folder"
  },
  "permissions": [
    {
      "scope": "filesystem",
      "access": "read",
      "reason": "Watch and read files from the folder selected by the user."
    },
    {
      "scope": "memory",
      "access": "write",
      "reason": "Save generated summaries into the user's local knowledge base."
    }
  ],
  "nodes": [
    {
      "id": "watch_downloads",
      "type": "filesystem.folder_watcher",
      "tool": "watch_folder",
      "name": "Watch Downloads",
      "category": "Filesystem",
      "config": {
        "folder_ref": "user.downloads_folder",
        "file_glob": "*.pdf",
        "ignore_existing": true
      }
    },
    {
      "id": "extract_pdf_text",
      "type": "document.extract_text",
      "tool": "extract_document_text",
      "name": "Extract PDF Text",
      "category": "Filesystem",
      "config": {
        "source_ref": "${watch_downloads.file_path}",
        "max_chars_ref": "workflow.max_document_chars"
      }
    },
    {
      "id": "summarize_pdf",
      "type": "ai.summarizer",
      "tool": "summarize_text",
      "name": "Summarize PDF",
      "category": "AI",
      "config": {
        "text_ref": "${extract_pdf_text.text}",
        "style": "concise_actionable",
        "provider_ref": "ai.default_provider"
      }
    },
    {
      "id": "save_summary",
      "type": "memory.note_writer",
      "tool": "memory_write",
      "name": "Save Summary",
      "category": "Memory",
      "config": {
        "title_template": "PDF Summary: ${watch_downloads.file_name}",
        "body_ref": "${summarize_pdf.summary}",
        "collection_ref": "memory.default_notes_collection"
      }
    },
    {
      "id": "notify_user",
      "type": "notifications.local",
      "tool": "notification",
      "name": "Notify User",
      "category": "Notifications",
      "config": {
        "message_template": "PDF summarized and saved: ${watch_downloads.file_name}"
      }
    }
  ],
  "edges": [
    {"from": "watch_downloads", "to": "extract_pdf_text"},
    {"from": "extract_pdf_text", "to": "summarize_pdf"},
    {"from": "summarize_pdf", "to": "save_summary"},
    {"from": "save_summary", "to": "notify_user"}
  ],
  "marketplace": {
    "one_click_install": true,
    "difficulty": "beginner",
    "preview_required": true,
    "local_first": true
  }
}
